PORT=4000

# The EXACT Channel ID that is allowed to connect.
# Only this value will be accepted from the login form.
THINGSPEAK_CHANNEL_ID=3281642

# The EXACT Read API Key for the channel above.
# Copy it from: thingspeak.mathworks.com → Channels → API Keys → Read API Keys
# Only this value will be accepted from the login form — any other key is rejected.
THINGSPEAK_READ_API_KEY=YOUR_REAL_16_CHAR_READ_KEY_HERE
